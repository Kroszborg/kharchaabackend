# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Get from: https://console.neon.tech → project → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/kharchaaa?sslmode=require"

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="replace_with_64_random_hex_chars"
JWT_REFRESH_SECRET="replace_with_different_64_random_hex_chars"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS — comma-separated allowed origins ────────────────────────────────────
# Production: your Vercel admin URL + mobile Expo URLs
CORS_ORIGIN=http://localhost:3001,https://kharchaaa-admin.vercel.app
